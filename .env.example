# Hardware profile — must be exactly one of: cpu | gpu-nvidia | gpu-amd
COMPOSE_PROFILES=cpu

OLLAMA_MODEL=llama3.2
OLLAMA_JUDGE_MODEL=mistral
OLLAMA_EMBED_MODEL=nomic-embed-text
MLFLOW_TRACKING_URI=http://mlflow:5000
CHROMA_PERSIST_DIR=/tmp/chroma
CHROMA_COLLECTION_NAME=ragscope_collection

# Required API protection for /ingest and /query.
# Clients must send header: X-API-Key: <value>
API_KEY=change-me

# Security guardrails
MAX_UPLOAD_SIZE_BYTES=10485760
MAX_TOP_K=20
MAX_CONTEXT_CHARS=20000
